{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "regions": ["hkg1"],
  "env": {
    "NEXT_PUBLIC_SITE_URL": {
      "description": "网站公开 URL"
    },
    "DATABASE_URL": {
      "description": "Prisma 数据库连接字符串",
      "dangerous": "true"
    },
    "NEXTAUTH_SECRET": {
      "description": "NextAuth 密钥",
      "dangerous": "true"
    },
    "NEXTAUTH_URL": {
      "description": "NextAuth URL"
    },
    "SENTRY_DSN": {
      "description": "Sentry DSN",
      "dangerous": "true"
    },
    "SENTRY_AUTH_TOKEN": {
      "description": "Sentry Auth Token",
      "dangerous": "true"
    }
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_SITE_URL": "https://wsnail.com"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ]
}
